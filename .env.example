# Vercel AI Gateway uses Vercel OIDC by default — `vercel env pull .env.local`
# writes a short-lived VERCEL_OIDC_TOKEN automatically. No per-provider key needed.
# Re-run `vercel env pull .env.local --yes` if the token expires (~24h TTL).

DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=

# Deepgram region — selects which Deepgram WebSocket endpoint the browser
# connects to. Set to `eu` for EU-detected traffic to keep audio data on
# EU infrastructure (GDPR Article 44-49 cross-border-transfer compliance).
# Values: `us` (default) | `eu`. Unknown values fall back to `us` with a
# console warning. See lib/client/deepgram-endpoint.ts for selector logic.
NEXT_PUBLIC_DEEPGRAM_REGION=us

# Public auth. If unset, v1 falls back to guest-first local saves.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Set to 1 only for deployments that should require account sign-in before
# opening sessions or cost-bearing model/transcription APIs.
YENTL_REQUIRE_AUTH=

# Shared launch rate limiter. Production should set YENTL_RATE_LIMIT_BACKEND=redis
# with either Upstash Redis REST or Vercel KV REST credentials.
YENTL_RATE_LIMIT_BACKEND=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob is required for client-direct uploads above the browser-safe
# multipart threshold.
BLOB_READ_WRITE_TOKEN=

# Claim-scope policy classifier. Production defaults to model classifier; set
# explicitly for preview smoke tests or to force deterministic local behavior.
YENTL_CLAIM_SCOPE_CLASSIFIER=model

# Internal validation demos. Leave disabled in public production builds unless
# a protected preview explicitly needs them.
NEXT_PUBLIC_YENTL_ENABLE_VALIDATION_DEMO=
YENTL_ENABLE_VALIDATION_DEMO=

# Public trust/contact emails. Defaults are support/privacy/accessibility at
# yentl.it, but production should set these to mailboxes that are live.
NEXT_PUBLIC_YENTL_SUPPORT_EMAIL=
NEXT_PUBLIC_YENTL_PRIVACY_EMAIL=
NEXT_PUBLIC_YENTL_ACCESSIBILITY_EMAIL=

# Phase 1d/1e — BIPA consent gate for speaker diarization (Illinois
# biometric-info law + Texas CUBI + Washington biometric privacy).
# Default: false (speaker labeling off; production audio collapses to
# 1 speaker). Set to "1" only after BIPA-compliant voiceprint disclosure
# copy ships AND the consent checkbox in the audio upload pane is wired
# (Phase 1e shipped the checkbox; legal text on the disclosure surface
# is on the lawyer). The env flag is the env-level kill switch; the
# per-call bipaConsented param is the per-upload gate. Both must be true
# for diarize to fire on the batch path. Live streaming always stays off.
YENTL_ENABLE_BIPA_DIARIZE=

# Phase 1d — trimodal eval base URL override. Default localhost:3000;
# point to a Vercel preview to run the eval against a deployed branch.
# Used only by scripts/experiments/yentl-trimodal-eval.ts — no runtime
# code reads this.
YENTL_BASE_URL=
