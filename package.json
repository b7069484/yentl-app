{
  "name": "yentl-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "mkdir -p bin && curl -sSL -o bin/yt-dlp https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp_linux && chmod +x bin/yt-dlp && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "corpus:resolve": "tsx --env-file=.env.local scripts/test-corpus/resolve-urls.ts",
    "corpus:ingest": "tsx --env-file=.env.local scripts/test-corpus/ingest-all.ts",
    "corpus:captions": "tsx --env-file=.env.local scripts/test-corpus/fetch-ground-truth.ts",
    "corpus:score-wer": "tsx --env-file=.env.local scripts/test-corpus/score-wer.ts",
    "corpus:replay": "tsx --env-file=.env.local scripts/test-corpus/replay.ts",
    "corpus:report": "tsx --env-file=.env.local scripts/test-corpus/report.ts",
    "corpus2:report": "tsx scripts/test-corpus-2/report.ts",
    "corpus2:resolve": "YENTL_CORPUS_DIR=test-corpus-2 tsx --env-file=.env.local scripts/test-corpus/resolve-urls.ts",
    "corpus2:ingest": "YENTL_CORPUS_DIR=test-corpus-2 tsx --env-file=.env.local scripts/test-corpus/ingest-all.ts",
    "corpus2:captions": "YENTL_CORPUS_DIR=test-corpus-2 tsx --env-file=.env.local scripts/test-corpus/fetch-ground-truth.ts",
    "corpus2:score-wer": "YENTL_CORPUS_DIR=test-corpus-2 tsx --env-file=.env.local scripts/test-corpus/score-wer.ts",
    "corpus2:replay": "YENTL_CORPUS_DIR=test-corpus-2 tsx --env-file=.env.local scripts/test-corpus/replay.ts",
    "ingest:taxonomy": "tsx --env-file=.env.local scripts/ingest-taxonomy-pdf.ts",
    "tag:archetypes": "tsx --env-file=.env.local scripts/tag-archetypes.ts",
    "apply:archetypes": "tsx scripts/apply-archetypes.ts",
    "visual:capture-launch": "tsx scripts/visual-evidence/capture-launch-screenshots.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "smoke:launch": "tsx scripts/launch-smoke.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@clerk/nextjs": "^7.3.7",
    "@deepgram/sdk": "^5.1.0",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.3.3",
    "ai": "^6.0.177",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "ogl": "^1.0.11",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ulid": "^3.0.2",
    "youtube-dl-exec": "^3.1.7",
    "youtube-transcript": "^1.3.1",
    "youtubei.js": "^17.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.40",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.6",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "pdf-parse": "^2.4.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "youtube-dl-exec"
    ]
  }
}
