{
  "name": "yentl-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:automation": "next build --webpack",
    "vercel-build": "mkdir -p bin && curl -sSL -o bin/yt-dlp https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp_linux && chmod +x bin/yt-dlp && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "corpus:resolve": "tsx --env-file=.env.local scripts/test-corpus/resolve-urls.ts",
    "corpus:ingest": "tsx --env-file=.env.local scripts/test-corpus/ingest-all.ts",
    "corpus:captions": "tsx --env-file=.env.local scripts/test-corpus/fetch-ground-truth.ts",
    "corpus:score-wer": "tsx --env-file=.env.local scripts/test-corpus/score-wer.ts",
    "corpus:replay": "tsx --env-file=.env.local scripts/test-corpus/replay.ts",
    "corpus:report": "tsx --env-file=.env.local scripts/test-corpus/report.ts",
    "corpus2:report": "tsx scripts/test-corpus-2/report.ts",
    "corpus2:resolve": "YENTL_CORPUS_DIR=test-corpus-2 tsx --env-file=.env.local scripts/test-corpus/resolve-urls.ts",
    "corpus2:ingest": "YENTL_CORPUS_DIR=test-corpus-2 tsx --env-file=.env.local scripts/test-corpus/ingest-all.ts",
    "corpus2:captions": "YENTL_CORPUS_DIR=test-corpus-2 tsx --env-file=.env.local scripts/test-corpus/fetch-ground-truth.ts",
    "corpus2:score-wer": "YENTL_CORPUS_DIR=test-corpus-2 tsx --env-file=.env.local scripts/test-corpus/score-wer.ts",
    "corpus2:replay": "YENTL_CORPUS_DIR=test-corpus-2 tsx --env-file=.env.local scripts/test-corpus/replay.ts",
    "speaker-attribution:score": "tsx scripts/test-corpus/score-speaker-attribution.ts",
    "speaker-attribution:report": "tsx scripts/test-corpus/report-speaker-attribution.ts",
    "ingest:taxonomy": "tsx --env-file=.env.local scripts/ingest-taxonomy-pdf.ts",
    "tag:archetypes": "tsx --env-file=.env.local scripts/tag-archetypes.ts",
    "apply:archetypes": "tsx scripts/apply-archetypes.ts",
    "visual:capture-launch": "tsx scripts/visual-evidence/capture-launch-screenshots.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "extension:check": "node scripts/validation/check-extension-package.mjs",
    "extension:proof:local": "node scripts/validation/prove-installed-extension-local.mjs",
    "extension:proof:external": "YENTL_EXTENSION_PROOF_TARGET_URL=https://commons.wikimedia.org/wiki/File:David_Korten,_The_Green_Interview.webm YENTL_EXTENSION_PROOF_MANUAL_CAPTURE=1 node scripts/validation/prove-installed-extension-local.mjs",
    "extension:latency:sample": "node scripts/validation/sample-extension-latency.mjs",
    "extension:proof:real-pages": "node scripts/validation/verify-real-webpage-targets.mjs",
    "ingestion:proof:local": "node scripts/validation/prove-ingestion-local.mjs",
    "ingestion:proof:ui": "node scripts/validation/prove-ingestion-ui-local.mjs",
    "ingestion:proof:deploy": "YENTL_INGESTION_PROOF_ORIGIN=https://yentl.it node scripts/validation/prove-ingestion-local.mjs",
    "ingestion:proof:large-real-media": "node scripts/validation/prove-large-real-media-canary.mjs",
    "ingestion:proof:text-docs": "tsx scripts/validation/prove-text-document-fixtures.ts",
    "analysis:proof:local": "node scripts/validation/prove-analysis-local.mjs",
    "analysis:proof:deploy:provisional": "YENTL_ANALYSIS_PROOF_ORIGIN=https://yentl.it YENTL_ANALYSIS_PROOF_VERIFY=provisional node scripts/validation/prove-analysis-local.mjs",
    "analysis:proof:deploy:confirmed": "YENTL_ANALYSIS_PROOF_ORIGIN=https://yentl.it YENTL_ANALYSIS_PROOF_VERIFY=confirmed node scripts/validation/prove-analysis-local.mjs",
    "analysis:proof:metaread": "tsx scripts/validation/prove-synthesis-metaread.ts",
    "analysis:proof:speaker-attribution": "tsx scripts/validation/prove-speaker-attribution.ts",
    "trust:proof:deploy": "node scripts/validation/prove-trust-copy-deploy.mjs",
    "a11y:proof:local": "YENTL_A11Y_PROOF_ORIGIN=http://127.0.0.1:3000 node scripts/validation/prove-a11y-deploy.mjs",
    "a11y:proof:deploy": "node scripts/validation/prove-a11y-deploy.mjs",
    "analysis:proof:deploy:both": "YENTL_ANALYSIS_PROOF_ORIGIN=https://yentl.it YENTL_ANALYSIS_PROOF_VERIFY=both YENTL_ANALYSIS_PROOF_IDS=solo_005 YENTL_ANALYSIS_PROOF_MAX_UTTERANCES=6 node scripts/validation/prove-analysis-local.mjs",
    "mobile:proof:local": "node scripts/validation/prove-mobile-pwa-local.mjs",
    "mobile:proof:devices": "node scripts/validation/prove-mobile-device-canary.mjs",
    "pwa:proof:native": "tsx scripts/validation/prove-pwa-native-contract.ts",
    "analysis:proof:sensitive-review": "node scripts/validation/prove-sensitive-attribution-review.mjs",
    "session:proof:local": "YENTL_SESSION_UX_PROOF_ORIGIN=http://localhost:3000 node scripts/validation/prove-session-ux-local.mjs",
    "cloud-sync:proof:local": "node scripts/validation/prove-cloud-sync-local.mjs",
    "cloud-sync:proof:deploy": "YENTL_CLOUD_SYNC_PROOF_ORIGIN=https://yentl.it node scripts/validation/prove-cloud-sync-local.mjs",
    "smoke:launch": "tsx scripts/launch-smoke.ts",
    "release:canary-templates": "node scripts/validation/create-launch-canary-templates.mjs",
    "release:readiness": "node scripts/validation/prove-release-readiness.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@clerk/nextjs": "^7.3.7",
    "@deepgram/sdk": "^5.1.0",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.3.3",
    "ai": "^6.0.177",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "ogl": "^1.0.11",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ulid": "^3.0.2",
    "youtube-dl-exec": "^3.1.7",
    "youtube-transcript": "^1.3.1",
    "youtubei.js": "^17.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.40",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.6",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "pdf-parse": "^2.4.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "youtube-dl-exec"
    ]
  }
}
